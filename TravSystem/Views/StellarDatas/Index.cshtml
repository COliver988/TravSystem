@model IEnumerable<TravSystem.Models.StellarData>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.StarTypeId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.StellarTypeId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Magnitude)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Luminosity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Temperature)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Radius)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Mass)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.StarType.Type)
            </td>
            <td>
                 @item.StellarType?.Type (@item.StellarType?.Size)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Magnitude)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Luminosity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Temperature)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Radius)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Mass)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
